# https://twiki.cern.ch/twiki/bin/viewauth/CMS/LumiRecommendationsRun3#Luminosity_for_pp_13_6_TeV_data, accessed 12 Nov 2024

brilcalc lumi --normtag /cvmfs/cms-bril.cern.ch/cms-lumi-pog/Normtags/normtag_BRIL.json --datatag online -u /fb -i Merged_Collisions26_401624_402537_Golden_401630_402825_MLEnhancedGolden_ML.json > 2026.txt
